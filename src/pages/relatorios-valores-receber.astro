---
import PageLayout from "~/layouts/PageLayout.astro";
import Loading from "~/components/widgets/Loading.astro";

const metadata = {
  title: "Relatórios - Valores a Receber",
  description: "Visualização do relatório de valores a receber",
};
---

<PageLayout metadata={metadata}>
  <Loading />
  <section class="mx-auto max-w-5xl px-4 py-8 sm:py-10">
    <div class="mb-6">
      <a
        href="/dashboard"
        class="mb-3 inline-flex min-h-11 items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
        aria-label="Voltar ao Dashboard"
        >Voltar ao Dashboard</a
      >
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white sm:text-3xl">
        Valores a Receber
      </h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        Lista de valores pendentes por paciente e mês.
      </p>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
        Clique em uma linha para revisar as sessões pendentes antes de confirmar o pagamento.
      </p>
    </div>

    <div class="overflow-x-auto rounded border bg-white p-3 shadow dark:border-gray-800 dark:bg-gray-900 sm:p-4">
      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="text-sm text-gray-600 dark:text-gray-400">
          Exibindo <span id="receber-count">0</span> registros
        </div>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-600 dark:text-gray-400">Por página:</span>
          <button type="button" class="per-page-btn rounded border px-3 py-1 text-sm" data-per-page="20">20</button>
          <button type="button" class="per-page-btn rounded border px-3 py-1 text-sm" data-per-page="50">50</button>
          <button type="button" class="per-page-btn rounded border px-3 py-1 text-sm" data-per-page="100">100</button>
        </div>
      </div>

      <table class="w-full table-auto text-left">
        <thead>
          <tr class="border-b text-sm text-gray-600 dark:border-gray-700 dark:text-gray-400">
            <th class="p-2">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <span>Nome</span>
                <input
                  id="name-filter"
                  type="text"
                  placeholder="Filtrar nome"
                  class="w-full rounded border bg-white px-2 py-1 text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white sm:w-56"
                />
              </div>
            </th>
            <th class="p-2">Mês</th>
            <th class="p-2">Total</th>
          </tr>
        </thead>
        <tbody id="receber-body" class="align-top text-sm">
          <tr>
            <td colspan="3" class="p-4 text-center text-sm text-gray-500">Carregando...</td>
          </tr>
        </tbody>
      </table>

      <div class="mt-4 flex items-center justify-between gap-3">
        <button
          id="prev-page-btn"
          type="button"
          class="rounded border px-3 py-1 text-sm disabled:cursor-not-allowed disabled:opacity-50">
          Anterior
        </button>
        <span id="page-indicator" class="text-sm text-gray-600 dark:text-gray-400">Página 1 de 1</span>
        <button
          id="next-page-btn"
          type="button"
          class="rounded border px-3 py-1 text-sm disabled:cursor-not-allowed disabled:opacity-50">
          Próxima
        </button>
      </div>
    </div>
  </section>

  <div
    id="bulk-payment-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="bulk-payment-title">
    <div class="w-full max-w-lg rounded-lg border border-gray-300 bg-white p-4 shadow-lg dark:border-gray-700 dark:bg-gray-900 sm:p-5">
      <h2 id="bulk-payment-title" class="text-lg font-semibold text-gray-900 dark:text-white">
        Confirmar pagamento das sessões
      </h2>
      <p id="bulk-payment-summary" class="mt-2 text-sm text-gray-600 dark:text-gray-300"></p>

      <div id="bulk-payment-loading" class="mt-3 hidden rounded border border-blue-200 bg-blue-50 px-3 py-2 text-sm text-blue-700">
        Carregando sessões pendentes...
      </div>

      <div id="bulk-payment-empty" class="mt-3 hidden rounded border border-yellow-200 bg-yellow-50 px-3 py-2 text-sm text-yellow-700">
        Nenhuma sessão pendente encontrada para este contexto.
      </div>

      <ul id="bulk-payment-list" class="mt-3 max-h-60 space-y-2 overflow-auto"></ul>

      <p id="bulk-payment-progress" class="mt-3 hidden text-sm text-gray-600 dark:text-gray-300"></p>
      <p id="bulk-payment-feedback" class="mt-2 hidden text-sm"></p>

      <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:justify-end">
        <button
          type="button"
          id="bulk-payment-cancel"
          class="inline-flex min-h-11 items-center justify-center rounded border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700">
          Cancelar
        </button>
        <button
          type="button"
          id="bulk-payment-confirm"
          class="inline-flex min-h-11 items-center justify-center rounded bg-green-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-green-700">
          Confirmar pagamento
        </button>
      </div>
    </div>
  </div>

  <script>
    import { getPaginationView, getPerPageValue } from "~/services/paginationService";
    import { ReportService } from "~/services/reportService";
    import { SessaoService } from "~/services/sessaoService";
    import type { ReportValoresReceberItem as ReportItem } from "~/types/relatorio";
    import type {
      BulkPayOwnerMonthPayload,
      PendingSessionPreviewItem,
    } from "~/types/sessao";

    type BulkPaymentContext = {
      ownerId: string;
      patientId: string;
      patientName: string;
      monthKey: string;
      monthLabel: string;
      total: number;
    };

    const byId = (id: string): HTMLElement | null => document.getElementById(id);

    let currentPage = 1;
    let perPage = 20;
    let totalPages = 1;
    let totalItems = 0;
    let nameFilter = "";
    let items: ReportItem[] = [];

    let selectedBulkPayment: BulkPaymentContext | null = null;
    let pendingPreviewItems: PendingSessionPreviewItem[] = [];

    const currencyFormatter = new Intl.NumberFormat("pt-BR", {
      style: "currency",
      currency: "BRL",
    });

    function getOwnerId(item: ReportItem): string {
      if (typeof item.owner_id === "string" && item.owner_id.trim()) return item.owner_id.trim();
      if (typeof item.ownerId === "string" && item.ownerId.trim()) return item.ownerId.trim();
      if (typeof item.owner === "string" && item.owner.trim()) return item.owner.trim();
      return "";
    }

    function getPatientId(item: ReportItem): string {
      if (typeof item.id_paciente === "string" && item.id_paciente.trim()) return item.id_paciente.trim();
      if (typeof item.paciente_id === "string" && item.paciente_id.trim()) return item.paciente_id.trim();
      if (typeof item.idPaciente === "string" && item.idPaciente.trim()) return item.idPaciente.trim();
      return "";
    }

    function getPatientName(item: ReportItem): string {
      if (typeof item.nome === "string" && item.nome.trim()) return item.nome.trim();
      if (typeof item.paciente === "string" && item.paciente.trim()) return item.paciente.trim();
      return "";
    }

    function getRowLabel(item: ReportItem): string {
      return getPatientName(item) || getOwnerId(item) || "Registro";
    }

    function normalizeMonthKey(value: unknown): string {
      if (typeof value !== "string") return "";
      const normalized = value.trim().toLowerCase();
      if (!normalized) return "";
      if (/^\d{4}-\d{2}$/.test(normalized)) return normalized;
      if (/^\d{4}\/\d{2}$/.test(normalized)) return normalized.replace("/", "-");

      const monthYear = normalized.match(/^(\d{1,2})\/(\d{4})$/);
      if (monthYear) {
        const month = Number(monthYear[1]);
        const year = Number(monthYear[2]);
        if (month >= 1 && month <= 12) {
          return `${year}-${String(month).padStart(2, "0")}`;
        }
      }

      const parsedDate = new Date(value);
      if (!Number.isNaN(parsedDate.getTime())) {
        return `${parsedDate.getUTCFullYear()}-${String(parsedDate.getUTCMonth() + 1).padStart(2, "0")}`;
      }

      return "";
    }

    function getMonthLabel(item: ReportItem): string {
      if (item.mes_ano) return String(item.mes_ano);
      if (item.mes !== undefined && item.mes !== null && String(item.mes).trim()) {
        return String(item.mes);
      }
      if (item.data) {
        const date = new Date(item.data);
        if (!Number.isNaN(date.getTime())) {
          return new Intl.DateTimeFormat("pt-BR", {
            month: "short",
            year: "numeric",
          })
            .format(date)
            .replace(".", "");
        }
      }
      return "-";
    }

    function getMonthKey(item: ReportItem): string {
      const fromMesAno = normalizeMonthKey(item.mes_ano);
      if (fromMesAno) return fromMesAno;

      const fromMes = normalizeMonthKey(
        item.mes !== undefined && item.mes !== null ? String(item.mes) : "",
      );
      if (fromMes) return fromMes;

      return normalizeMonthKey(item.data ?? "");
    }

    function formatSessionLine(item: PendingSessionPreviewItem): string {
      const date = new Date(item.data);
      const dateLabel = Number.isNaN(date.getTime())
        ? item.data
        : new Intl.DateTimeFormat("pt-BR", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          }).format(date);

      const patient = item.pacienteNome?.trim() || "Paciente";
      return `${patient} • ${dateLabel} • ${currencyFormatter.format(Number(item.valor) || 0)}`;
    }

    function setFeedbackMessage(message: string, type: "success" | "error" | "info") {
      const feedback = byId("bulk-payment-feedback");
      if (!feedback) return;

      feedback.textContent = message;
      feedback.classList.remove("hidden", "text-red-600", "text-green-600", "text-gray-600");

      if (type === "success") feedback.classList.add("text-green-600");
      else if (type === "error") feedback.classList.add("text-red-600");
      else feedback.classList.add("text-gray-600");
    }

    function clearFeedbackMessage() {
      const feedback = byId("bulk-payment-feedback");
      if (!feedback) return;
      feedback.textContent = "";
      feedback.classList.add("hidden");
      feedback.classList.remove("text-red-600", "text-green-600", "text-gray-600");
    }

    function setProgressMessage(message: string | null) {
      const progress = byId("bulk-payment-progress");
      if (!progress) return;

      if (!message) {
        progress.classList.add("hidden");
        progress.textContent = "";
        return;
      }

      progress.textContent = message;
      progress.classList.remove("hidden");
    }

    function renderPreviewList(itemsToRender: PendingSessionPreviewItem[]) {
      const listEl = byId("bulk-payment-list");
      if (!listEl) return;

      if (!itemsToRender.length) {
        listEl.innerHTML = "";
        return;
      }

      listEl.innerHTML = itemsToRender
        .map(
          (item) =>
            `<li class="rounded border border-gray-200 bg-gray-50 px-2 py-2 text-xs text-gray-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200">${formatSessionLine(item)}</li>`,
        )
        .join("");
    }

    function togglePreviewLoading(show: boolean) {
      const loading = byId("bulk-payment-loading");
      if (!loading) return;
      loading.classList.toggle("hidden", !show);
    }

    function togglePreviewEmpty(show: boolean) {
      const empty = byId("bulk-payment-empty");
      if (!empty) return;
      empty.classList.toggle("hidden", !show);
    }

    function setConfirmButtonState(disabled: boolean, label = "Confirmar pagamento") {
      const confirmButton = byId("bulk-payment-confirm") as HTMLButtonElement | null;
      if (!confirmButton) return;
      confirmButton.disabled = disabled;
      confirmButton.textContent = label;
    }

    function setCancelButtonState(disabled: boolean) {
      const cancelButton = byId("bulk-payment-cancel") as HTMLButtonElement | null;
      if (!cancelButton) return;
      cancelButton.disabled = disabled;
    }

    function getPreviewPayload(context: BulkPaymentContext): BulkPayOwnerMonthPayload {
      return {
        monthKey: context.monthKey,
        ownerId: context.ownerId || undefined,
        patientId: context.patientId || undefined,
        patientName: context.patientName || undefined,
      };
    }

    async function loadPendingPreview(context: BulkPaymentContext) {
      const summary = byId("bulk-payment-summary");
      const patientLabel = context.patientName || "o contexto selecionado";
      if (summary) {
        summary.textContent =
          `Buscando sessões pendentes de ${patientLabel} no mês ${context.monthLabel}...`;
      }

      clearFeedbackMessage();
      setProgressMessage(null);
      togglePreviewEmpty(false);
      renderPreviewList([]);
      togglePreviewLoading(true);
      setConfirmButtonState(true, "Carregando...");

      try {
        const preview = await SessaoService.getPendingSessionsPreview(
          getPreviewPayload(context),
        );
        pendingPreviewItems = Array.isArray(preview.items) ? preview.items : [];

        const totalValue = pendingPreviewItems.reduce(
          (acc, item) => acc + (Number(item.valor) || 0),
          0,
        );

        if (summary) {
          summary.textContent =
            `Foram encontradas ${pendingPreviewItems.length} sessão(ões) pendente(s) para ${patientLabel} em ${context.monthLabel}, totalizando ${currencyFormatter.format(totalValue)}.`;
        }

        renderPreviewList(pendingPreviewItems);
        togglePreviewEmpty(pendingPreviewItems.length === 0);
        setConfirmButtonState(pendingPreviewItems.length === 0);
      } catch (error) {
        console.error(error);
        pendingPreviewItems = [];
        togglePreviewEmpty(true);
        setConfirmButtonState(true);
        setFeedbackMessage("Falha ao carregar sessões pendentes para confirmação.", "error");
      } finally {
        togglePreviewLoading(false);
      }
    }

    function openBulkPaymentModal(context: BulkPaymentContext) {
      selectedBulkPayment = context;
      const modal = byId("bulk-payment-modal");
      if (!modal) return;

      modal.classList.remove("hidden");
      modal.classList.add("flex");
      loadPendingPreview(context);
    }

    function closeBulkPaymentModal() {
      const modal = byId("bulk-payment-modal");
      if (!modal) return;

      modal.classList.add("hidden");
      modal.classList.remove("flex");
      selectedBulkPayment = null;
      pendingPreviewItems = [];
      clearFeedbackMessage();
      setProgressMessage(null);
      togglePreviewLoading(false);
      togglePreviewEmpty(false);
      renderPreviewList([]);
      setConfirmButtonState(false);
      setCancelButtonState(false);
    }

    async function confirmBulkPayment() {
      if (!selectedBulkPayment) return;
      if (!pendingPreviewItems.length) {
        setFeedbackMessage("Não há sessões pendentes para confirmar.", "info");
        return;
      }

      setCancelButtonState(true);
      setConfirmButtonState(true, "Confirmando...");
      clearFeedbackMessage();

      let updatedCount = 0;
      try {
        for (let index = 0; index < pendingPreviewItems.length; index += 1) {
          const session = pendingPreviewItems[index];
          setProgressMessage(`Confirmando ${index + 1} de ${pendingPreviewItems.length}...`);

          const result = await SessaoService.paySingleSession({
            sessionId: session.id,
            monthKey: selectedBulkPayment.monthKey,
            ownerId: selectedBulkPayment.ownerId || undefined,
            patientId: session.id_paciente || selectedBulkPayment.patientId || undefined,
            patientName: session.pacienteNome || selectedBulkPayment.patientName || undefined,
          });

          if (result.updated) {
            updatedCount += 1;
          }
        }

        setProgressMessage(null);
        setFeedbackMessage(
          `Pagamento concluído. ${updatedCount} sessão(ões) confirmada(s).`,
          "success",
        );

        await loadData(currentPage);
        window.setTimeout(() => {
          closeBulkPaymentModal();
        }, 900);
      } catch (error) {
        console.error(error);
        setProgressMessage(null);
        setFeedbackMessage(
          `Falha ao confirmar pagamentos. ${updatedCount} sessão(ões) já atualizada(s).`,
          "error",
        );
        setConfirmButtonState(false);
        setCancelButtonState(false);
      }
    }

    function escapeAttribute(value: string): string {
      return value
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }

    async function loadData(page = 1) {
      const body = byId("receber-body");
      try {
        const data = await ReportService.getValoresReceber(page, perPage);

        currentPage = data.page;
        totalPages = data.totalPages;
        totalItems = data.totalItems;
        items = data.items;

        render();
        updatePaginationControls();
        updateCount();
      } catch (err) {
        console.error(err);
        if (body) {
          body.innerHTML =
            '<tr><td colspan="3" class="p-4 text-center text-red-500">Erro ao carregar relatório.</td></tr>';
        }
      }
    }

    function render() {
      const body = byId("receber-body");
      if (!body) return;

      const query = nameFilter.trim().toLowerCase();
      const filtered = !query
        ? items
        : items.filter((item) => getRowLabel(item).toLowerCase().includes(query));

      if (!filtered.length) {
        body.innerHTML =
          '<tr><td colspan="3" class="p-4 text-center text-gray-500">Nenhum registro encontrado.</td></tr>';
        return;
      }

      body.innerHTML = filtered
        .map((item) => {
          const ownerId = getOwnerId(item);
          const patientId = getPatientId(item);
          const patientName = getPatientName(item);
          const monthLabel = getMonthLabel(item);
          const monthKey = getMonthKey(item);
          const label = getRowLabel(item);
          const total = Number(item.total) || 0;
          const canSettle = Boolean(monthKey);

          return `
            <tr
              class="receber-row border-t transition dark:border-gray-800 ${
                canSettle
                  ? "cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800"
                  : "cursor-not-allowed opacity-60"
              }"
              data-receber-row
              data-can-settle="${canSettle ? "true" : "false"}"
              data-owner-id="${escapeAttribute(ownerId)}"
              data-patient-id="${escapeAttribute(patientId)}"
              data-patient-name="${escapeAttribute(patientName)}"
              data-month-key="${escapeAttribute(monthKey)}"
              data-month-label="${escapeAttribute(monthLabel)}"
              data-total="${String(total)}"
              tabindex="0"
              role="button"
              aria-label="Revisar pagamento de ${escapeAttribute(label)} no mês ${escapeAttribute(monthLabel)}">
              <td class="p-2 dark:text-gray-300">
                ${escapeAttribute(label)}
                 <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">${
                   canSettle
                     ? "Clique para revisar sessões antes de confirmar"
                     : "Registro sem mês válido"
                 }</p>
               </td>
              <td class="p-2 dark:text-gray-300">${escapeAttribute(monthLabel)}</td>
              <td class="p-2 font-medium dark:text-white">${currencyFormatter.format(total)}</td>
            </tr>
          `;
        })
        .join("");

      attachRowListeners();
    }

    function attachRowListeners() {
      document.querySelectorAll("[data-receber-row]").forEach((row) => {
        if (row.getAttribute("data-row-bound") === "true") return;
        row.setAttribute("data-row-bound", "true");

        const openFromRow = () => {
          if (row.getAttribute("data-can-settle") !== "true") return;

          const context: BulkPaymentContext = {
            ownerId: row.getAttribute("data-owner-id") || "",
            patientId: row.getAttribute("data-patient-id") || "",
            patientName: row.getAttribute("data-patient-name") || "",
            monthKey: row.getAttribute("data-month-key") || "",
            monthLabel: row.getAttribute("data-month-label") || "-",
            total: Number(row.getAttribute("data-total") || "0") || 0,
          };

          openBulkPaymentModal(context);
        };

        row.addEventListener("click", openFromRow);
        row.addEventListener("keydown", (event) => {
          const keyboardEvent = event as KeyboardEvent;
          if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
            event.preventDefault();
            openFromRow();
          }
        });
      });
    }

    function attachFilterListener() {
      const input = byId("name-filter") as HTMLInputElement | null;
      if (!input || input.dataset.bound === "true") return;
      input.dataset.bound = "true";

      input?.addEventListener("input", () => {
        nameFilter = input.value;
        render();
      });
    }

    function attachPerPageListeners() {
      document.querySelectorAll(".per-page-btn").forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        if (btn.dataset.bound === "true") return;
        btn.dataset.bound = "true";

        btn.addEventListener("click", () => {
          perPage = getPerPageValue(btn.getAttribute("data-per-page"), 20);
          currentPage = 1;
          updatePerPageButtons();
          loadData(currentPage);
        });
      });
    }

    function attachPaginationListeners() {
      const prevBtn = byId("prev-page-btn");
      if (prevBtn && prevBtn.dataset.bound !== "true") {
        prevBtn.dataset.bound = "true";
        prevBtn.addEventListener("click", () => {
          if (currentPage <= 1) return;
          loadData(currentPage - 1);
        });
      }

      const nextBtn = byId("next-page-btn");
      if (nextBtn && nextBtn.dataset.bound !== "true") {
        nextBtn.dataset.bound = "true";
        nextBtn.addEventListener("click", () => {
          if (currentPage >= totalPages) return;
          loadData(currentPage + 1);
        });
      }
    }

    function attachModalListeners() {
      const cancelBtn = byId("bulk-payment-cancel");
      if (cancelBtn && cancelBtn.dataset.bound !== "true") {
        cancelBtn.dataset.bound = "true";
        cancelBtn.addEventListener("click", () => {
          const cancelButton = byId("bulk-payment-cancel") as HTMLButtonElement | null;
          if (cancelButton?.disabled) return;
          closeBulkPaymentModal();
        });
      }

      const confirmBtn = byId("bulk-payment-confirm");
      if (confirmBtn && confirmBtn.dataset.bound !== "true") {
        confirmBtn.dataset.bound = "true";
        confirmBtn.addEventListener("click", confirmBulkPayment);
      }

      const modal = byId("bulk-payment-modal");
      if (modal && modal.dataset.bound !== "true") {
        modal.dataset.bound = "true";
        modal.addEventListener("click", (event) => {
          if (event.target === event.currentTarget) {
            const cancelButton = byId("bulk-payment-cancel") as HTMLButtonElement | null;
            if (!cancelButton?.disabled) {
              closeBulkPaymentModal();
            }
          }
        });
      }
    }

    function updatePerPageButtons() {
      document.querySelectorAll(".per-page-btn").forEach((btn) => {
        const isActive = Number(btn.getAttribute("data-per-page")) === perPage;
        btn.classList.toggle("bg-blue-600", isActive);
        btn.classList.toggle("text-white", isActive);
        btn.classList.toggle("border-blue-600", isActive);
      });
    }

    function updatePaginationControls() {
      const prevBtn = byId("prev-page-btn") as HTMLButtonElement | null;
      const nextBtn = byId("next-page-btn") as HTMLButtonElement | null;
      const indicator = byId("page-indicator");

      const view = getPaginationView(currentPage, totalPages);
      if (prevBtn) prevBtn.disabled = !view.canPrev;
      if (nextBtn) nextBtn.disabled = !view.canNext;
      if (indicator) indicator.textContent = view.indicator;
    }

    function updateCount() {
      const countEl = byId("receber-count");
      if (countEl) countEl.textContent = String(totalItems);
    }

    function attachBannerListeners() {
      const closeBtn = byId("close-receber-banner");
      if (!closeBtn || closeBtn.dataset.bound === "true") return;
      closeBtn.dataset.bound = "true";

      closeBtn.addEventListener("click", () => {
        byId("receber-info-banner")?.classList.add("hidden");
      });
    }

    async function init() {
      const body = byId("receber-body");
      if (!body) return;
      if (body.dataset.initialized === "true") return;
      body.dataset.initialized = "true";

      const pbAuth = localStorage.getItem("pb_auth");
      if (!pbAuth) {
        window.location.href = "/login";
        return;
      }

      attachFilterListener();
      attachPerPageListeners();
      attachPaginationListeners();
      attachModalListeners();
      attachBannerListeners();
      updatePerPageButtons();
      updatePaginationControls();
      await loadData();
    }

    document.addEventListener("astro:page-load", init);
    init();
  </script>

  <style is:inline>
    .lilac #bulk-payment-feedback.text-green-600 {
      color: rgb(167 243 208);
    }

    .lilac #bulk-payment-feedback.text-red-600 {
      color: rgb(252 165 165);
    }

    .lilac #bulk-payment-feedback.text-gray-600 {
      color: rgb(221 214 254);
    }
  </style>
</PageLayout>
