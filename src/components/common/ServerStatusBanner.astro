---
const serverUrl =
  import.meta.env.PUBLIC_POCKETBASE_URL ||
  "https://gawiga-server.bonito-dace.ts.net/";
---

<div data-server-status-banner class="pointer-events-none fixed inset-x-0 top-0 z-[70] hidden px-3 pt-3 sm:px-4">
  <div
    data-server-status-content
    class="pointer-events-auto mx-auto max-w-5xl rounded-md border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-800 shadow">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="font-semibold">Servidor indisponível</p>
        <p class="text-xs sm:text-sm">
          Não foi possível conectar em <span class="font-medium">{serverUrl}</span>. Alguns dados podem não carregar.
        </p>
      </div>
      <button
        type="button"
        data-server-status-dismiss
        class="inline-flex min-h-9 min-w-9 items-center justify-center rounded border border-red-300 bg-white/80 px-2 text-xs font-semibold text-red-700 transition hover:bg-red-100"
        aria-label="Fechar aviso de servidor indisponível">
        Fechar
      </button>
    </div>
  </div>
</div>

<style is:inline>
  .dark [data-server-status-content] {
    border-color: rgb(248 113 113 / 0.55);
    background-color: rgb(127 29 29 / 0.65);
    color: rgb(254 226 226);
  }

  .lilac [data-server-status-content] {
    border-color: rgb(196 181 253 / 0.75);
    background-color: rgb(88 28 135 / 0.65);
    color: rgb(250 245 255);
  }

  .lilac [data-server-status-dismiss] {
    border-color: rgb(196 181 253 / 0.75);
    background-color: rgb(30 21 50 / 0.8);
    color: rgb(250 245 255);
  }
</style>

<script>
  if (document.documentElement.dataset.serverStatusBannerInit !== "true") {
    document.documentElement.dataset.serverStatusBannerInit = "true";

    async function checkServerStatus() {
      const banner = document.querySelector("[data-server-status-banner]");
      if (!banner) return;

      try {
        const response = await fetch("/api/health/server", {
          method: "GET",
          credentials: "same-origin",
          cache: "no-store",
        });

        if (response.ok) {
          banner.classList.add("hidden");
          return;
        }

        banner.classList.remove("hidden");
      } catch {
        banner.classList.remove("hidden");
      }
    }

    function attachDismissAction() {
      const banner = document.querySelector(
        "[data-server-status-banner]",
      ) as HTMLElement | null;
      const dismissBtn = document.querySelector(
        "[data-server-status-dismiss]",
      ) as HTMLButtonElement | null;
      if (!banner || !dismissBtn || dismissBtn.dataset.bound === "true") return;

      dismissBtn.dataset.bound = "true";
      dismissBtn.addEventListener("click", () => {
        banner.classList.add("hidden");
      });
    }

    function initServerStatusBanner() {
      attachDismissAction();
      checkServerStatus();
    }

    document.addEventListener("astro:page-load", initServerStatusBanner);

    if (document.readyState === "complete") {
      initServerStatusBanner();
    } else {
      document.addEventListener("DOMContentLoaded", initServerStatusBanner);
    }

    setInterval(checkServerStatus, 60000);
  }
</script>
