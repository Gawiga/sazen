---
interface Props {
  user?: Record<string, unknown> | null;
}

const { user = null } = Astro.props;

function resolveDisplayName(source: Record<string, unknown> | null): string {
  if (!source) return "Usuário";

  const candidates = [source.name, source.username, source.nome, source.email];

  for (const value of candidates) {
    if (typeof value === "string" && value.trim().length > 0) {
      return value.trim();
    }
  }

  return "Usuário";
}

const displayName = resolveDisplayName((user as Record<string, unknown>) ?? null);
const email = typeof user?.email === "string" ? user.email : "";
---

<div data-user-menu class="flex min-h-11 items-center gap-2 sm:gap-3">
  <div class="hidden min-w-[11rem] sm:block">
    <p data-user-email class="truncate text-xs text-gray-500 dark:text-gray-400">{email}</p>
  </div>
  <div class="text-right">
    <p
      data-user-greeting
      class="text-sm font-medium text-gray-900 opacity-100 transition-opacity duration-200 dark:text-white">
      Olá {displayName}
    </p>
  </div>
  <button
    data-logout-btn
    class="inline-flex min-h-10 items-center justify-center rounded-md px-3 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800">
    Sair
  </button>
</div>

<script>
  type UserData = Record<string, unknown> | null;
  type UserMenuWindow = Window & {
    __userMenuFetchPromise?: Promise<UserData>;
  };

  function getTokenFromLocalStorage() {
    const rawAuth = localStorage.getItem("pb_auth");
    if (!rawAuth) return null;

    try {
      const parsed = JSON.parse(rawAuth);
      return typeof parsed?.token === "string" ? parsed.token : null;
    } catch {
      return typeof rawAuth === "string" ? rawAuth : null;
    }
  }

  function getUserFromLocalStorage() {
    const rawAuth = localStorage.getItem("pb_auth");
    if (!rawAuth) return null;

    try {
      const parsed = JSON.parse(rawAuth);
      return parsed?.model || parsed?.record || null;
    } catch {
      return null;
    }
  }

  function resolveName(user: UserData) {
    if (!user || typeof user !== "object") return "Usuário";

    const candidates = [user.name, user.username, user.nome, user.email];
    for (const value of candidates) {
      if (typeof value === "string" && value.trim().length > 0) {
        return value.trim();
      }
    }

    return "Usuário";
  }

  function updateMenuContent(menu: Element, user: UserData, withFade = false) {
    const userEmail = menu.querySelector("[data-user-email]");
    const userGreeting = menu.querySelector("[data-user-greeting]");

    if (userEmail) {
      userEmail.textContent = typeof user?.email === "string" ? user.email : "";
    }

    if (!userGreeting) return;

    const nextGreeting = `Olá ${resolveName(user)}`;
    if (userGreeting.textContent === nextGreeting) return;

    if (!withFade) {
      userGreeting.textContent = nextGreeting;
      return;
    }

    userGreeting.classList.add("opacity-0");
    requestAnimationFrame(() => {
      userGreeting.textContent = nextGreeting;
      userGreeting.classList.remove("opacity-0");
    });
  }

  async function fetchCurrentUser() {
    try {
      const token = getTokenFromLocalStorage();
      const headers = new Headers();
      if (token) {
        headers.set("Authorization", `Bearer ${token}`);
      }

      const response = await fetch("/api/auth/user", {
        method: "GET",
        headers,
        credentials: "include",
      });

      if (!response.ok) return null;
      const data = await response.json();
      const payload = data?.user?.payload || data?.user?.record || data?.user || null;
      return payload && typeof payload === "object" ? payload : null;
    } catch {
      return null;
    }
  }

  async function fetchCurrentUserCached() {
    const userMenuWindow = window as UserMenuWindow;
    if (!userMenuWindow.__userMenuFetchPromise) {
      userMenuWindow.__userMenuFetchPromise = fetchCurrentUser().finally(() => {
        userMenuWindow.__userMenuFetchPromise = undefined;
      });
    }

    return userMenuWindow.__userMenuFetchPromise;
  }

  async function handleLogout() {
    try {
      window.showLoading?.();
      const response = await fetch("/api/auth/logout", {
        method: "POST",
      });

      if (!response.ok) return;

      localStorage.removeItem("pb_auth");
      window.location.href = "/";
    } catch (error) {
      console.error("Logout error:", error);
    } finally {
      window.hideLoading?.();
    }
  }

  function bindLogout(menu: Element) {
    const logoutBtn = menu.querySelector(
      "[data-logout-btn]",
    ) as HTMLButtonElement | null;
    if (!logoutBtn || logoutBtn.dataset.bound === "true") return;
    logoutBtn.dataset.bound = "true";
    logoutBtn.addEventListener("click", handleLogout);
  }

  async function initUserMenus() {
    const menus = Array.from(
      document.querySelectorAll("[data-user-menu]"),
    ) as HTMLElement[];
    if (!menus.length) return;

    const fallbackUser = getUserFromLocalStorage();
    menus.forEach((menu) => {
      bindLogout(menu);
      if (menu.dataset.userFallbackApplied !== "true") {
        updateMenuContent(menu, fallbackUser, false);
        menu.dataset.userFallbackApplied = "true";
      }
    });

    const shouldFetchRemote = menus.some(
      (menu) => menu.dataset.userRemoteLoaded !== "true",
    );
    if (!shouldFetchRemote) return;

    const fetchedUser = await fetchCurrentUserCached();
    const mergedUser =
      fetchedUser && fallbackUser
        ? { ...fallbackUser, ...fetchedUser }
        : fetchedUser || fallbackUser;

    if (!mergedUser) return;

    menus.forEach((menu) => {
      updateMenuContent(menu, mergedUser, true);
      menu.dataset.userRemoteLoaded = "true";
    });
  }

  document.addEventListener("astro:page-load", initUserMenus);
  initUserMenus();
</script>
